<%
  const logoUrl = (theme && theme.logoUrl) || (process.env.THEME_DEFAULT_LOGO_URL || '').trim() || null;
  const siteName = (theme && theme.siteName) || (theme && theme.brandName) || 'Site';
%>
<!DOCTYPE html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bakım Çalışması · <%= siteName %></title>
    <meta name="robots" content="noindex, nofollow" />
    <% if (theme && theme.faviconUrl) { %>
      <link rel="icon" href="<%= theme.faviconUrl %>" />
    <% } %>
    <% if (theme && theme.primaryColor) { %>
      <meta name="theme-color" content="<%= theme.primaryColor %>">
    <% } %>
    <link rel="stylesheet" href="/assets/tailwind.css" />
    <% if (theme) { %>
    <style>
      :root {
        --color-primary: <%= theme.primaryColor %>;
        --color-secondary: <%= theme.secondaryColor %>;
        --color-accent: <%= theme.accentColor %>;
        --color-background: <%= theme.backgroundColor %>;
        --color-surface: <%= theme.surfaceColor %>;
        --color-text: <%= theme.textColor %>;
        --color-text-muted: <%= theme.mutedTextColor %>;
        --color-border: <%= theme.borderColor %>;
      }
    </style>
    <% } %>
  </head>
  <body style="background-color: var(--color-background, #F1F5F9); color: var(--color-text, #0F172A);" class="min-h-screen">
    <div class="flex min-h-screen flex-col items-center justify-center px-4 py-16 text-center">

      <% if (logoUrl) { %>
        <div class="mb-8">
          <img
            src="<%= logoUrl %>"
            alt="<%= siteName %>"
            class="mx-auto max-h-20 w-auto object-contain"
          />
        </div>
      <% } %>

      <div class="w-full max-w-lg rounded-2xl border p-10 shadow-sm"
           style="background-color: var(--color-surface, #fff); border-color: var(--color-border, rgba(15,23,42,0.12));">

        <div class="mb-6 flex justify-center">
          <span class="inline-flex h-16 w-16 items-center justify-center rounded-full"
                style="background-color: color-mix(in srgb, var(--color-primary, #1E73BE) 12%, transparent);">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24"
                 stroke="currentColor" stroke-width="1.5"
                 style="color: var(--color-primary, #1E73BE);">
              <path stroke-linecap="round" stroke-linejoin="round"
                    d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l5.653-4.655m5.8-5.8 1.875-1.875a3.375 3.375 0 0 1 4.773 4.773l-1.87 1.875M14.854 9.13l-4.655 5.653"/>
            </svg>
          </span>
        </div>

        <h1 class="mb-3 text-2xl font-bold" style="color: var(--color-primary, #1E73BE);">
          Bakım Çalışması
        </h1>

        <p class="mb-2 text-base font-medium" style="color: var(--color-text, #0F172A);">
          Sitemiz şu anda bakım çalışmaları nedeniyle geçici olarak erişime kapalıdır.
        </p>

        <p class="text-sm" style="color: var(--color-text-muted, #4B5563);">
          En kısa sürede tekrar hizmetinizde olacağız. Anlayışınız için teşekkür ederiz.
        </p>

      </div>

      <p class="mt-8 text-xs" style="color: var(--color-text-muted, #4B5563);">
        &copy; <%= new Date().getFullYear() %> <%= siteName %>
      </p>

    </div>
  </body>
</html>
